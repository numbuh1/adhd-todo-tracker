<div class="module-card weekly-module">

  <!-- ── Weekly Goals ──────────────────────────────────────── -->
  <div class="module-header">
    <span class="module-icon">🎯</span>
    <h2 class="module-title">This Week's Goals</h2>
    <span class="week-badge"><%= weekStart %></span>
  </div>

  <div class="goals-section">
    <% if (goals && goals.length > 0) { %>
      <% goals.forEach(goal => { %>
      <label class="todo-label<%= goal.completed ? ' completed' : '' %>"
             data-week-id="<%= weekId %>"
             data-goal-id="<%= goal._id %>"
             data-type="goal">
        <input type="checkbox"
               class="todo-check"
               onclick="event.stopPropagation()"
               <%= goal.completed ? 'checked' : '' %>>
        <span class="todo-text"><%= goal.text %></span>
      </label>
      <% }); %>
    <% } else { %>
      <p class="no-items">No goals set for this week.</p>
    <% } %>
  </div>

  <div class="section-divider"></div>

  <!-- ── Daily To-Dos ───────────────────────────────────────── -->
  <div class="days-grid">
    <% days.forEach(day => { %>
    <div class="day-column<%= day.isToday ? ' day-today' : '' %>">
      <div class="day-header">
        <span class="day-label"><%= day.dateLabel %></span>
        <%# Always render badge to keep height consistent; hide it for non-today %>
        <span class="today-badge" style="visibility: <%= day.isToday ? 'visible' : 'hidden' %>">today</span>
      </div>

      <div class="day-todos">
        <% if (day.todos && day.todos.length > 0) { %>
          <% day.todos.forEach(todo => { %>
          <label class="todo-label<%= todo.completed ? ' completed' : '' %>"
                 data-week-id="<%= weekId %>"
                 data-day-index="<%= day.dayIndex %>"
                 data-todo-id="<%= todo._id %>"
                 data-type="todo">
            <input type="checkbox"
                   class="todo-check"
                   onclick="event.stopPropagation()"
                   <%= todo.completed ? 'checked' : '' %>>
            <span class="todo-text"><%= todo.text %></span>
          </label>
          <% }); %>
        <% } else { %>
          <span class="no-items-sm">—</span>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>

</div>
