<div class="module-card overall-todos-module">

  <div class="module-header">
    <span class="module-icon">📝</span>
    <h2 class="module-title">To-Do List</h2>
  </div>

  <% if (!items || items.length === 0) { %>
    <p class="no-items">No to-dos yet. <a href="<%= basePath %>/admin/overall-todos" style="color:var(--accent)">Add some →</a></p>
  <% } else { %>
  <div class="overall-todos-list">
    <% items.forEach(item => { %>
    <label class="todo-label<%= item.completed ? ' completed' : '' %>"
           data-doc-id="<%= docId %>"
           data-item-id="<%= item._id %>"
           data-type="overall">
      <input type="checkbox"
             class="todo-check"
             onclick="event.stopPropagation()"
             <%= item.completed ? 'checked' : '' %>>
      <span class="todo-text"><%= item.text %></span>
    </label>
    <% }); %>
  </div>
  <% } %>

</div>
