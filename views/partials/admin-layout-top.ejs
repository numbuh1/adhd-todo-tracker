<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ADHD Tracker Admin</title>
  <link rel="stylesheet" href="<%= basePath %>/css/admin.css">
</head>
<body>

<div class="admin-wrapper">
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">🧠</span>
      <span class="brand-name">ADHD Tracker</span>
    </div>
    <nav class="sidebar-nav">
      <a href="<%= basePath %>/admin" class="nav-item<%= activePage === 'home' ? ' active' : '' %>">
        <span class="nav-icon">🏠</span> Dashboard
      </a>
      <a href="<%= basePath %>/admin/calendar" class="nav-item<%= activePage === 'calendar' ? ' active' : '' %>">
        <span class="nav-icon">📅</span> Calendar & Events
      </a>
      <a href="<%= basePath %>/admin/weekly-todos" class="nav-item<%= activePage === 'weekly-todos' ? ' active' : '' %>">
        <span class="nav-icon">✅</span> Weekly To-Dos
      </a>
      <a href="<%= basePath %>/admin/habit-tracker" class="nav-item<%= activePage === 'habit-tracker' ? ' active' : '' %>">
        <span class="nav-icon">🔥</span> Habit Tracker
      </a>
      <a href="<%= basePath %>/admin/music-player" class="nav-item<%= activePage === 'music-player' ? ' active' : '' %>">
        <span class="nav-icon">🎵</span> Music Player
      </a>
      <a href="<%= basePath %>/admin/progress" class="nav-item<%= activePage === 'progress' ? ' active' : '' %>">
        <span class="nav-icon">📊</span> Progress Tracker
      </a>
      <a href="<%= basePath %>/admin/overall-todos" class="nav-item<%= activePage === 'overall-todos' ? ' active' : '' %>">
        <span class="nav-icon">📋</span> Overall To-Dos
      </a>
      <a href="<%= basePath %>/admin/video-player" class="nav-item<%= activePage === 'video-player' ? ' active' : '' %>">
        <span class="nav-icon">🎬</span> Video Player
      </a>
      <a href="<%= basePath %>/admin/recurring-todos" class="nav-item<%= activePage === 'recurring-todos' ? ' active' : '' %>">
        <span class="nav-icon">🔁</span> Recurring To-Dos
      </a>
      <a href="<%= basePath %>/admin/settings" class="nav-item<%= activePage === 'settings' ? ' active' : '' %>">
        <span class="nav-icon">⚙️</span> Settings
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="<%= basePath %>/" target="_blank" class="view-dashboard-btn">
        📊 Open Dashboard
      </a>
      <!-- User info + logout -->
      <div class="sidebar-user">
        <span class="sidebar-user-name">👤 <%= currentUser ? currentUser.username : 'User' %></span>
        <form action="<%= basePath %>/logout" method="POST" style="margin:0">
          <button type="submit" class="sidebar-logout-btn">Sign Out</button>
        </form>
      </div>
    </div>
  </aside>

  <!-- Main area -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="topbar-title"><%= title %></h1>
    </div>
