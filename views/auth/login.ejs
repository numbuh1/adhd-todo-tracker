<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — ADHD Tracker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0a0a16;
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .auth-card {
      width: 100%;
      max-width: 380px;
      background: #12122a;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 2.5rem 2rem;
    }
    .auth-brand {
      text-align: center;
      margin-bottom: 2rem;
    }
    .auth-logo  { font-size: 2.5rem; }
    .auth-title { font-size: 1.3rem; font-weight: 700; margin-top: .4rem; }
    .auth-sub   { font-size: .82rem; color: #94a3b8; margin-top: .25rem; }

    .form-group { margin-bottom: 1.1rem; }
    label { display: block; font-size: .82rem; color: #94a3b8; margin-bottom: .35rem; }
    input[type="text"], input[type="password"] {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      padding: .65rem .85rem;
      color: #e2e8f0;
      font-size: .9rem;
      outline: none;
      transition: border-color .2s;
    }
    input:focus { border-color: #7c3aed; }

    .btn-submit {
      width: 100%;
      padding: .75rem;
      background: #7c3aed;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: .95rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: .5rem;
      transition: filter .2s;
    }
    .btn-submit:hover { filter: brightness(1.12); }

    .auth-footer {
      text-align: center;
      margin-top: 1.5rem;
      font-size: .82rem;
      color: #94a3b8;
    }
    .auth-footer a { color: #7c3aed; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }

    .error-msg {
      background: rgba(248,113,113,0.12);
      border: 1px solid rgba(248,113,113,0.3);
      border-radius: 8px;
      padding: .65rem .85rem;
      font-size: .82rem;
      color: #fca5a5;
      margin-bottom: 1.25rem;
    }
  </style>
</head>
<body>
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-logo">🧠</div>
      <div class="auth-title">ADHD Tracker</div>
      <div class="auth-sub">Sign in to your workspace</div>
    </div>

    <% if (error) { %>
    <div class="error-msg">⚠️ <%= error %></div>
    <% } %>

    <form action="<%= basePath %>/login" method="POST">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username"
               autocomplete="username" autofocus required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password"
               autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn-submit">Sign In →</button>
    </form>

    <div class="auth-footer">
      Don't have an account? <a href="register">Create one</a>
    </div>
  </div>
</body>
</html>
